# Cloudflare Workers Static Assets headers

# styles.css é sempre versionado via ?v=cssVersion() (cache-busting por deploy),
# então pode ser cacheado como immutable — a URL muda sozinha quando o CSS muda.
/styles.css
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=86400, s-maxage=604800

/favicon.ico
  Cache-Control: public, max-age=86400, s-maxage=604800
