{
  "name": "capitulo-de-hoje",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create capitulo-de-hoje",
    "db:migrate:local": "wrangler d1 execute capitulo-de-hoje --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute capitulo-de-hoje --remote --file=./schema.sql",
    "db:console:local": "wrangler d1 execute capitulo-de-hoje --local --command",
    "db:console:remote": "wrangler d1 execute capitulo-de-hoje --remote --command"
  },
  "dependencies": {
    "@cf-wasm/photon": "^0.3.6",
    "marked": "^14.1.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251111.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.90.1"
  }
}
